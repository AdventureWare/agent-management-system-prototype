{
	"name": "agent-management-system-prototype",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"predev": "node scripts/check-vite-compat.mjs",
		"dev": "node --env-file-if-exists=.env.local ./node_modules/vite/bin/vite.js dev",
		"prebuild": "node scripts/check-vite-compat.mjs",
		"build": "node --env-file-if-exists=.env.local ./node_modules/vite/bin/vite.js build",
		"prepreview": "node scripts/check-vite-compat.mjs",
		"preview": "node --env-file-if-exists=.env.local ./node_modules/vite/bin/vite.js preview",
		"app:server:run": "node --env-file-if-exists=.env.local scripts/operator-server.mjs run",
		"app:server:start": "node --env-file-if-exists=.env.local scripts/operator-server.mjs start",
		"app:server:stop": "node --env-file-if-exists=.env.local scripts/operator-server.mjs stop",
		"app:server:status": "node --env-file-if-exists=.env.local scripts/operator-server.mjs status",
		"agent:threads": "node --env-file-if-exists=.env.local scripts/agent-thread-cli.mjs",
		"app:launchd:install": "node --env-file-if-exists=.env.local scripts/operator-launchd.mjs install",
		"app:launchd:uninstall": "node --env-file-if-exists=.env.local scripts/operator-launchd.mjs uninstall",
		"app:launchd:status": "node --env-file-if-exists=.env.local scripts/operator-launchd.mjs status",
		"remote:access:start": "node --env-file-if-exists=.env.local scripts/remote-access.mjs start",
		"remote:access:stop": "node --env-file-if-exists=.env.local scripts/remote-access.mjs stop",
		"remote:access:status": "node --env-file-if-exists=.env.local scripts/remote-access.mjs status",
		"remote:tailscale:start": "AMS_REMOTE_ACCESS_PROVIDER=tailscale node --env-file-if-exists=.env.local scripts/remote-access.mjs start",
		"remote:tailscale:stop": "AMS_REMOTE_ACCESS_PROVIDER=tailscale node --env-file-if-exists=.env.local scripts/remote-access.mjs stop",
		"remote:tailscale:status": "AMS_REMOTE_ACCESS_PROVIDER=tailscale node --env-file-if-exists=.env.local scripts/remote-access.mjs status",
		"remote:phone:start": "node --env-file-if-exists=.env.local scripts/remote-phone-access.mjs start",
		"remote:phone:stop": "node --env-file-if-exists=.env.local scripts/remote-phone-access.mjs stop",
		"remote:phone:status": "node --env-file-if-exists=.env.local scripts/remote-phone-access.mjs status",
		"prepare": "node scripts/setup-git-hooks.mjs && (svelte-kit sync || echo '')",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"db:export-json": "node scripts/app-db.mjs export-json",
		"db:import-json": "node scripts/app-db.mjs import-json",
		"db:migrate": "node scripts/app-db.mjs migrate",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"test:unit": "vitest --project server",
		"test:unit:browser": "VITEST_BROWSER=1 vitest --project client",
		"test": "npm run test:unit -- --run && npm run test:e2e",
		"test:e2e": "playwright test",
		"knip": "knip"
	},
	"devDependencies": {
		"@eslint/compat": "^2.0.2",
		"@eslint/js": "^10.0.1",
		"@playwright/test": "^1.58.1",
		"@skeletonlabs/skeleton": "^4.12.1",
		"@skeletonlabs/skeleton-svelte": "^4.12.1",
		"@sveltejs/adapter-auto": "^7.0.0",
		"@sveltejs/adapter-node": "^5.5.4",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.1.18",
		"@types/better-sqlite3": "^7.6.13",
		"@types/node": "^22.19.17",
		"@vitest/browser-playwright": "^4.0.18",
		"eslint": "^10.2.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.14.0",
		"globals": "^17.3.0",
		"knip": "^6.4.1",
		"playwright": "^1.58.1",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.4.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"svelte": "^5.51.0",
		"svelte-check": "^4.3.6",
		"tailwindcss": "^4.1.18",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.54.0",
		"vite": "^7.3.2",
		"vite-plugin-devtools-json": "^1.0.0",
		"vitest": "^4.0.18",
		"vitest-browser-svelte": "^2.0.2"
	},
	"dependencies": {
		"@lucide/svelte": "^1.7.0",
		"better-sqlite3": "^12.8.0"
	}
}
