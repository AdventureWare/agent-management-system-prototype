# Copy this file to .env.local for machine-local settings.

# Shared operator password used by the remote login screen.
AMS_OPERATOR_PASSWORD=replace-this-with-a-strong-password

# Secret used to sign the remote operator session cookie.
AMS_OPERATOR_SESSION_SECRET=replace-this-with-a-long-random-secret

# Local app server settings used by the production-style Node runtime.
AMS_APP_HOST=127.0.0.1
AMS_APP_PORT=3000

# Preferred remote access provider for the vendor-neutral wrapper.
AMS_REMOTE_ACCESS_PROVIDER=tailscale
