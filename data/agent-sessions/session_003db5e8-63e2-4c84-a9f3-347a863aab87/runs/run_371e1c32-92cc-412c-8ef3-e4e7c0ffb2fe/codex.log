th}>{option.label}</option>\n    76\t\t\t\t\t\t{/each}\n    77\t\t\t\t\t</select>\n    78\t\t\t\t</label>\n    79\t\n    80\t\t\t\t<label class=\"block\">\n    81\t\t\t\t\t<span class=\"mb-2 block text-sm font-medium text-slate-200\">Repository or folder path</span>\n    82\t\t\t\t\t<input\n    83\t\t\t\t\t\tbind:value={cwd}\n    84\t\t\t\t\t\tclass=\"w-full rounded-lg border border-slate-700 bg-slate-900 px-3 py-2 text-white\"\n    85\t\t\t\t\t\tlist=\"folder-path-options\"\n    86\t\t\t\t\t\tname=\"cwd\"\n    87\t\t\t\t\t\tplaceholder=\"/Users/colinfreed/Projects/Products/Kwipoo/app\"\n    88\t\t\t\t\t\trequired\n    89\t\t\t\t\t/>\n    90\t\t\t\t</label>\n    91\t\n    92\t\t\t\t<datalist id=\"folder-path-options\">\n    93\t\t\t\t\t{#each data.folderOptions as option (option.path)}\n    94\t\t\t\t\t\t<option value={option.path}>{option.label}</option>\n    95\t\t\t\t\t{/each}\n    96\t\t\t\t</datalist>\n    97\t\n    98\t\t\t\t<div class=\"grid gap-4 sm:grid-cols-2\">\n    99\t\t\t\t\t<label class=\"block\">\n   100\t\t\t\t\t\t<span class=\"mb-2 block text-sm font-medium text-slate-200\">Sandbox</span>\n   101\t\t\t\t\t\t<select\n   102\t\t\t\t\t\t\tclass=\"w-full rounded-lg border border-slate-700 bg-slate-900 px-3 py-2 text-white\"\n   103\t\t\t\t\t\t\tname=\"sandbox\"\n   104\t\t\t\t\t\t>\n   105\t\t\t\t\t\t\t{#each data.sandboxOptions as sandbox (sandbox)}\n   106\t\t\t\t\t\t\t\t<option value={sandbox}>{sandbox}</option>\n   107\t\t\t\t\t\t\t{/each}\n   108\t\t\t\t\t\t</select>\n   109\t\t\t\t\t</label>\n   110\t\n   111\t\t\t\t\t<label class=\"block\">\n   112\t\t\t\t\t\t<span class=\"mb-2 block text-sm font-medium text-slate-200\">Model</span>\n   113\t\t\t\t\t\t<input\n   114\t\t\t\t\t\t\tclass=\"w-full rounded-lg border border-slate-700 bg-slate-900 px-3 py-2 text-white\"\n   115\t\t\t\t\t\t\tname=\"model\"\n   116\t\t\t\t\t\t\tplaceholder=\"optional\"\n   117\t\t\t\t\t\t/>\n   118\t\t\t\t\t</label>\n   119\t\t\t\t</div>\n   120\t\n   121\t\t\t\t<label class=\"block\">\n   122\t\t\t\t\t<span class=\"mb-2 block text-sm font-medium text-slate-200\">Task instructions</span>\n   123\t\t\t\t\t<textarea\n   124\t\t\t\t\t\tclass=\"min-h-40 w-full rounded-lg border border-slate-700 bg-slate-900 px-3 py-2 text-white\"\n   125\t\t\t\t\t\tname=\"prompt\"\n   126\t\t\t\t\t\tplaceholder=\"Read the repo, inspect AGENTS.md, then implement the bug fix and run validation.\"\n   127\t\t\t\t\t\trequired\n   128\t\t\t\t\t></textarea>\n   129\t\t\t\t</label>\n   130\t\n   131\t\t\t\t<button class=\"rounded-lg bg-sky-500 px-4 py-2 font-medium text-slate-950\" type=\"submit\">\n   132\t\t\t\t\tStart background Codex run\n   133\t\t\t\t</button>\n   134\t\t\t</form>\n   135\t\n   136\t\t\t<section class=\"rounded-2xl border border-slate-800 bg-slate-950/70 p-6\">\n   137\t\t\t\t<div class=\"flex items-center justify-between gap-3\">\n   138\t\t\t\t\t<h2 class=\"text-xl font-semibold text-white\">Current runs</h2>\n   139\t\t\t\t\t<p class=\"text-xs text-slate-500\">Refresh the page to update statuses.</p>\n   140\t\t\t\t</div>\n   141\t\n   142\t\t\t\t<div class=\"mt-4 space-y-4\">\n   143\t\t\t\t\t{#if data.sessions.length === 0}\n   144\t\t\t\t\t\t<p class=\"text-sm text-slate-400\">No runs yet.</p>\n   145\t\t\t\t\t{:else}\n   146\t\t\t\t\t\t{#each data.sessions as session (session.id)}\n   147\t\t\t\t\t\t\t<article class=\"space-y-4 rounded-xl border border-slate-800 bg-slate-900/60 p-4\">\n   148\t\t\t\t\t\t\t\t<div class=\"flex flex-wrap items-start justify-between gap-3\">\n   149\t\t\t\t\t\t\t\t\t<div>\n   150\t\t\t\t\t\t\t\t\t\t<h3 class=\"font-medium text-white\">{session.name}</h3>\n   151\t\t\t\t\t\t\t\t\t\t<p class=\"mt-1 text-xs text-slate-500\">{session.cwd}</p>\n   152\t\t\t\t\t\t\t\t\t</div>\n   153\t\t\t\t\t\t\t\t\t<div class=\"flex items-center gap-2\">\n   154\t\t\t\t\t\t\t\t\t\t<span\n   155\t\t\t\t\t\t\t\t\t\t\tclass=\"rounded-full border border-slate-700 px-2 py-1 text-xs text-slate-300 uppercase\"\n   156\t\t\t\t\t\t\t\t\t\t>\n   157\t\t\t\t\t\t\t\t\t\t\t{session.sandbox}\n   158\t\t\t\t\t\t\t\t\t\t</span>\n   159\t\t\t\t\t\t\t\t\t\t<span\n   160\t\t\t\t\t\t\t\t\t\t\tclass={[\n   161\t\t\t\t\t\t\t\t\t\t\t\t'rounded-full px-2 py-1 text-xs uppercase',\n   162\t\t\t\t\t\t\t\t\t\t\t\tsession.status === 'running' &&\n   163\t\t\t\t\t\t\t\t\t\t\t\t\t'border border-emerald-800/70 bg-emerald-950/50 text-emerald-300',\n   164\t\t\t\t\t\t\t\t\t\t\t\tsession.status === 'queued' &&\n   165\t\t\t\t\t\t\t\t\t\t\t\t\t'border border-amber-800/70 bg-amber-950/50 text-amber-300',\n   166\t\t\t\t\t\t\t\t\t\t\t\tsession.status === 'completed' &&\n   167\t\t\t\t\t\t\t\t\t\t\t\t\t'border border-sky-800/70 bg-sky-950/50 text-sky-300',\n   168\t\t\t\t\t\t\t\t\t\t\t\tsession.status === 'failed' &&\n   169\t\t\t\t\t\t\t\t\t\t\t\t\t'border border-rose-900/70 bg-rose-950/40 text-rose-300',\n   170\t\t\t\t\t\t\t\t\t\t\t\tsession.status === 'canceled' &&\n   171\t\t\t\t\t\t\t\t\t\t\t\t\t'border border-slate-700 bg-slate-900 text-slate-300',\n   172\t\t\t\t\t\t\t\t\t\t\t\tsession.status === 'idle' &&\n   173\t\t\t\t\t\t\t\t\t\t\t\t\t'border border-slate-700 bg-slate-900 text-slate-300'\n   174\t\t\t\t\t\t\t\t\t\t\t]}\n   175\t\t\t\t\t\t\t\t\t\t>\n   176\t\t\t\t\t\t\t\t\t\t\t{session.status}\n   177\t\t\t\t\t\t\t\t\t\t</span>\n   178\t\t\t\t\t\t\t\t\t</div>\n   179\t\t\t\t\t\t\t\t</div>\n   180\t\n   181\t\t\t\t\t\t\t\t<p class=\"text-xs text-slate-500\">\n   182\t\t\t\t\t\t\t\t\tstatus {session.status} · thread {session.threadId ?? 'not discovered yet'}\n   183\t\t\t\t\t\t\t\t</p>\n   184\t\n   185\t\t\t\t\t\t\t\t{#if session.latestRun}\n   186\t\t\t\t\t\t\t\t\t<div class=\"space-y-2 rounded-lg border border-slate-800 bg-slate-950/70 p-3\">\n   187\t\t\t\t\t\t\t\t\t\t<p class=\"text-xs font-medium tracking-[0.16em] text-slate-400 uppercase\">\n   188\t\t\t\t\t\t\t\t\t\t\tAssigned task\n   189\t\t\t\t\t\t\t\t\t\t</p>\n   190\t\t\t\t\t\t\t\t\t\t<p class=\"text-sm whitespace-pre-wrap text-slate-300\">\n   191\t\t\t\t\t\t\t\t\t\t\t{session.latestRun.prompt}\n   192\t\t\t\t\t\t\t\t\t\t</p>\n   193\t\t\t\t\t\t\t\t\t</div>\n   194\t\t\t\t\t\t\t\t{/if}\n   195\t\n   196\t\t\t\t\t\t\t\t{#if session.latestRun?.lastMessage}\n   197\t\t\t\t\t\t\t\t\t<div class=\"space-y-2 rounded-lg border border-slate-800 bg-slate-950/70 p-3\">\n   198\t\t\t\t\t\t\t\t\t\t<p class=\"text-xs font-medium tracking-[0.16em] text-slate-400 uppercase\">\n   199\t\t\t\t\t\t\t\t\t\t\tLast agent message\n   200\t\t\t\t\t\t\t\t\t\t</p>\n   201\t\t\t\t\t\t\t\t\t\t<p class=\"text-sm whitespace-pre-wrap text-slate-200\">\n   202\t\t\t\t\t\t\t\t\t\t\t{session.latestRun.lastMessage}\n   203\t\t\t\t\t\t\t\t\t\t</p>\n   204\t\t\t\t\t\t\t\t\t</div>\n   205\t\t\t\t\t\t\t\t{/if}\n   206\t\n   207\t\t\t\t\t\t\t\t{#if session.latestRun?.logTail?.length}\n   208\t\t\t\t\t\t\t\t\t<div class=\"space-y-2 rounded-lg border border-slate-800 bg-black/40 p-3\">\n   209\t\t\t\t\t\t\t\t\t\t<p class=\"text-xs font-medium tracking-[0.16em] text-slate-400 uppercase\">\n   210\t\t\t\t\t\t\t\t\t\t\tRecent log\n   211\t\t\t\t\t\t\t\t\t\t</p>\n   212\t\t\t\t\t\t\t\t\t\t<pre\n   213\t\t\t\t\t\t\t\t\t\t\tclass=\"max-h-72 overflow-auto text-xs whitespace-pre-wrap text-slate-300\">{session.latestRun.logTail.join(\n   214\t\t\t\t\t\t\t\t\t\t\t\t'\\n'\n   215\t\t\t\t\t\t\t\t\t\t\t)}</pre>\n   216\t\t\t\t\t\t\t\t\t</div>\n   217\t\t\t\t\t\t\t\t{/if}\n   218\t\n   219\t\t\t\t\t\t\t\t<div class=\"grid gap-3 lg:grid-cols-[1fr_auto]\">\n   220\t\t\t\t\t\t\t\t\t<form class=\"space-y-3\" method=\"POST\" action=\"?/sendMessage\">\n   221\t\t\t\t\t\t\t\t\t\t<input type=\"hidden\" name=\"sessionId\" value={session.id} />\n   222\t\t\t\t\t\t\t\t\t\t<textarea\n   223\t\t\t\t\t\t\t\t\t\t\tclass=\"min-h-28 w-full rounded-lg border border-slate-700 bg-slate-950 px-3 py-2 text-white disabled:opacity-50\"\n   224\t\t\t\t\t\t\t\t\t\t\tname=\"prompt\"\n   225\t\t\t\t\t\t\t\t\t\t\tplaceholder={session.canResume\n   226\t\t\t\t\t\t\t\t\t\t\t\t? 'Send a follow-up task update or instruction.'\n   227\t\t\t\t\t\t\t\t\t\t\t\t: session.hasActiveRun\n   228\t\t\t\t\t\t\t\t\t\t\t\t\t? 'Wait for the current run to finish before sending another instruction.'\n   229\t\t\t\t\t\t\t\t\t\t\t\t\t: 'This run cannot resume until a thread id is discovered.'}\n   230\t\t\t\t\t\t\t\t\t\t\tdisabled={!session.canResume}\n   231\t\t\t\t\t\t\t\t\t\t></textarea>\n   232\t\t\t\t\t\t\t\t\t\t<button\n   233\t\t\t\t\t\t\t\t\t\t\tclass=\"rounded-lg border border-slate-700 px-4 py-2 font-medium text-slate-100 disabled:opacity-50\"\n   234\t\t\t\t\t\t\t\t\t\t\ttype=\"submit\"\n   235\t\t\t\t\t\t\t\t\t\t\tdisabled={!session.canResume}\n   236\t\t\t\t\t\t\t\t\t\t>\n   237\t\t\t\t\t\t\t\t\t\t\tSend follow-up instruction\n   238\t\t\t\t\t\t\t\t\t\t</button>\n   239\t\t\t\t\t\t\t\t\t</form>\n   240\t\n   241\t\t\t\t\t\t\t\t\t{#if session.hasActiveRun}\n   242\t\t\t\t\t\t\t\t\t\t<form class=\"flex items-start\" method=\"POST\" action=\"?/cancelRun\">\n   243\t\t\t\t\t\t\t\t\t\t\t<input type=\"hidden\" name=\"sessionId\" value={session.id} />\n   244\t\t\t\t\t\t\t\t\t\t\t<button\n   245\t\t\t\t\t\t\t\t\t\t\t\tclass=\"rounded-lg border border-rose-900/70 bg-rose-950/30 px-4 py-2 font-medium text-rose-200\"\n   246\t\t\t\t\t\t\t\t\t\t\t\ttype=\"submit\"\n   247\t\t\t\t\t\t\t\t\t\t\t>\n   248\t\t\t\t\t\t\t\t\t\t\t\tCancel run\n   249\t\t\t\t\t\t\t\t\t\t\t</button>\n   250\t\t\t\t\t\t\t\t\t\t</form>\n   251\t\t\t\t\t\t\t\t\t{/if}\n   252\t\t\t\t\t\t\t\t</div>\n   253\t\t\t\t\t\t\t</article>\n   254\t\t\t\t\t\t{/each}\n   255\t\t\t\t\t{/if}\n   256\t\t\t\t</div>\n   257\t\t\t</section>\n   258\t\t</div>\n   259\t</section>\n","exit_code":0,"status":"completed"}}
