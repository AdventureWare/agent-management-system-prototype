{"type":"item.completed","item":{"id":"item_66","type":"command_execution","command":"/bin/zsh -lc \"nl -ba src/routes/api/workers/register/+server.ts | sed -n '1,220p'\"","aggregated_output":"     1\timport { json } from '@sveltejs/kit';\n     2\timport {\n     3\t\tcreateWorker,\n     4\t\tloadControlPlane,\n     5\t\tparseWorkerLocation,\n     6\t\tparseWorkerStatus,\n     7\t\tupdateControlPlane\n     8\t} from '$lib/server/control-plane';\n     9\timport {\n    10\t\tassertBootstrapToken,\n    11\t\tcreateWorkerAuthToken,\n    12\t\thashWorkerToken,\n    13\t\ttoPublicWorker\n    14\t} from '$lib/server/worker-api';\n    15\t\n    16\texport const POST = async ({ request }) => {\n    17\t\tconst body = (await request.json()) as {\n    18\t\t\tbootstrapToken?: string;\n    19\t\t\tname?: string;\n    20\t\t\tproviderId?: string;\n    21\t\t\troleId?: string;\n    22\t\t\tlocation?: string;\n    23\t\t\tstatus?: string;\n    24\t\t\tcapacity?: number;\n    25\t\t\tnote?: string;\n    26\t\t\ttags?: string[];\n    27\t\t};\n    28\t\n    29\t\tassertBootstrapToken(body.bootstrapToken);\n    30\t\n    31\t\tconst name = body.name?.trim() ?? '';\n    32\t\tconst providerId = body.providerId?.trim() ?? '';\n    33\t\tconst roleId = body.roleId?.trim() ?? '';\n    34\t\n    35\t\tif (!name || !providerId || !roleId) {\n    36\t\t\treturn json({ error: 'name, providerId, and roleId are required.' }, { status: 400 });\n    37\t\t}\n    38\t\n    39\t\tconst data = await loadControlPlane();\n    40\t\tconst provider = data.providers.find((candidate) => candidate.id === providerId);\n    41\t\tconst role = data.roles.find((candidate) => candidate.id === roleId);\n    42\t\n    43\t\tif (!provider) {\n    44\t\t\treturn json({ error: 'Unknown providerId.' }, { status: 400 });\n    45\t\t}\n    46\t\n    47\t\tif (!role) {\n    48\t\t\treturn json({ error: 'Unknown roleId.' }, { status: 400 });\n    49\t\t}\n    50\t\n    51\t\tconst workerToken = createWorkerAuthToken();\n    52\t\tlet createdWorkerId = '';\n    53\t\n    54\t\tawait updateControlPlane((current) => {\n    55\t\t\tconst worker = createWorker({\n    56\t\t\t\tname,\n    57\t\t\t\tproviderId,\n    58\t\t\t\troleId,\n    59\t\t\t\tlocation: parseWorkerLocation(body.location ?? '', 'cloud'),\n    60\t\t\t\tstatus: parseWorkerStatus(body.status ?? '', 'idle'),\n    61\t\t\t\tcapacity:\n    62\t\t\t\t\ttypeof body.capacity === 'number' && Number.isFinite(body.capacity) && body.capacity > 0\n    63\t\t\t\t\t\t? body.capacity\n    64\t\t\t\t\t\t: 1,\n    65\t\t\t\tnote: body.note?.trim() ?? '',\n    66\t\t\t\ttags: Array.isArray(body.tags) ? body.tags.map((tag) => tag.trim()).filter(Boolean) : []\n    67\t\t\t});\n    68\t\n    69\t\t\tworker.authTokenHash = hashWorkerToken(workerToken);\n    70\t\t\tcreatedWorkerId = worker.id;\n    71\t\n    72\t\t\treturn {\n    73\t\t\t\t...current,\n    74\t\t\t\tworkers: [worker, ...current.workers]\n    75\t\t\t};\n    76\t\t});\n    77\t\n    78\t\tconst nextData = await loadControlPlane();\n    79\t\tconst createdWorker = nextData.workers.find((worker) => worker.id === createdWorkerId);\n    80\t\n    81\t\treturn json(\n    82\t\t\t{\n    83\t\t\t\tworker: createdWorker ? toPublicWorker(createdWorker) : null,\n    84\t\t\t\tworkerToken\n    85\t\t\t},\n    86\t\t\t{ status: 201 }\n    87\t\t);\n    88\t};\n","exit_code":0,"status":"completed"}}
