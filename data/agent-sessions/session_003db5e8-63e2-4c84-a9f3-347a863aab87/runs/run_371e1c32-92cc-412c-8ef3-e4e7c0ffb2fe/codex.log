an).slice(-lineCount);\n   167\t}\n   168\t\n   169\tfunction compareByCreatedAtDesc<T extends { createdAt: string }>(left: T, right: T) {\n   170\t\treturn right.createdAt.localeCompare(left.createdAt);\n   171\t}\n   172\t\n   173\tasync function buildRunDetail(run: AgentRun): Promise<AgentRunDetail> {\n   174\t\tconst [state, lastMessage, logTail] = await Promise.all([\n   175\t\t\treadRunState(run.statePath),\n   176\t\t\treadOptionalText(run.messagePath),\n   177\t\t\treadLogTail(run.logPath)\n   178\t\t]);\n   179\t\n   180\t\treturn {\n   181\t\t\t...run,\n   182\t\t\tstate,\n   183\t\t\tlastMessage: lastMessage?.trim() || null,\n   184\t\t\tlogTail\n   185\t\t};\n   186\t}\n   187\t\n   188\tfunction getDiscoveredThreadId(session: AgentSession, runs: AgentRunDetail[]) {\n   189\t\tif (session.threadId) {\n   190\t\t\treturn session.threadId;\n   191\t\t}\n   192\t\n   193\t\tfor (const run of runs) {\n   194\t\t\tif (run.state?.codexThreadId) {\n   195\t\t\t\treturn run.state.codexThreadId;\n   196\t\t\t}\n   197\t\t}\n   198\t\n   199\t\treturn null;\n   200\t}\n   201\t\n   202\tfunction getSessionStatus(runs: AgentRunDetail[]) {\n   203\t\tconst latestRun = runs[0] ?? null;\n   204\t\n   205\t\tif (!latestRun?.state) {\n   206\t\t\treturn 'idle' as const;\n   207\t\t}\n   208\t\n   209\t\treturn latestRun.state.status;\n   210\t}\n   211\t\n   212\tfunction hasActiveRun(runs: AgentRunDetail[]) {\n   213\t\treturn runs.some((run) => run.state?.status === 'queued' || run.state?.status === 'running');\n   214\t}\n   215\t\n   216\tasync function buildSessionDetail(session: AgentSession, runs: AgentRun[]) {\n   217\t\tconst runDetails = await Promise.all(\n   218\t\t\t[...runs].sort(compareByCreatedAtDesc).map((run) => buildRunDetail(run))\n   219\t\t);\n   220\t\tconst threadId = getDiscoveredThreadId(session, runDetails);\n   221\t\tconst status = getSessionStatus(runDetails);\n   222\t\n   223\t\treturn {\n   224\t\t\t...session,\n   225\t\t\tthreadId,\n  