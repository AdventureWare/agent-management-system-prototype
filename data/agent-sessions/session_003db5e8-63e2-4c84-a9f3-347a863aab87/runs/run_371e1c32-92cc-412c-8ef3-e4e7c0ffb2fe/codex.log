{#if session.latestRun?.logTail?.length}\n\t\t\t\t\t\t\t\t<div class=\"space-y-2 rounded-lg border border-slate-800 bg-black/40 p-3\">\n\t\t\t\t\t\t\t\t\t<p class=\"text-xs font-medium tracking-[0.16em] text-slate-400 uppercase\">\n\t\t\t\t\t\t\t\t\t\tRecent log\n\t\t\t\t\t\t\t\t\t</p>\n\t\t\t\t\t\t\t\t\t<pre\n\t\t\t\t\t\t\t\t\t\tclass=\"max-h-72 overflow-auto text-xs whitespace-pre-wrap text-slate-300\">{session.latestRun.logTail.join(\n\t\t\t\t\t\t\t\t\t\t\t'\\n'\n\t\t\t\t\t\t\t\t\t\t)}</pre>\n\t\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t\t{/if}\n\n\t\t\t\t\t\t\t<div class=\"grid gap-3 lg:grid-cols-[1fr_auto]\">\n\t\t\t\t\t\t\t\t<form class=\"space-y-3\" method=\"POST\" action=\"?/sendMessage\">\n\t\t\t\t\t\t\t\t\t<input type=\"hidden\" name=\"sessionId\" value={session.id} />\n\t\t\t\t\t\t\t\t\t<textarea\n\t\t\t\t\t\t\t\t\t\tclass=\"min-h-28 w-full rounded-lg border border-slate-700 bg-slate-950 px-3 py-2 text-white disabled:opacity-50\"\n\t\t\t\t\t\t\t\t\t\tname=\"prompt\"\n\t\t\t\t\t\t\t\t\t\tplaceholder={session.canResume\n\t\t\t\t\t\t\t\t\t\t\t? 'Send a follow-up task update or instruction.'\n\t\t\t\t\t\t\t\t\t\t\t: session.hasActiveRun\n\t\t\t\t\t\t\t\t\t\t\t\t? 'Wait for the current run to finish before sending another instruction.'\n\t\t\t\t\t\t\t\t\t\t\t\t: 'This run cannot resume until a thread id is discovered.'}\n\t\t\t\t\t\t\t\t\t\tdisabled={!session.canResume}\n\t\t\t\t\t\t\t\t\t></textarea>\n\t\t\t\t\t\t\t\t\t<button\n\t\t\t\t\t\t\t\t\t\tclass=\"rounded-lg border border-slate-700 px-4 py-2 font-medium text-slate-100 disabled:opacity-50\"\n\t\t\t\t\t\t\t\t\t\ttype=\"submit\"\n\t\t\t\t\t\t\t\t\t\tdisabled={!session.canResume}\n\t\t\t\t\t\t\t\t\t>\n\t\t\t\t\t\t\t\t\t\tSend follow-up instruction\n\t\t\t\t\t\t\t\t\t</button>\n\t\t\t\t\t\t\t\t</form>\n\n\t\t\t\t\t\t\t\t{#if session.hasActiveRun}\n\t\t\t\t\t\t\t\t\t<form class=\"flex items-start\" method=\"POST\" action=\"?/cancelRun\">\n\t\t\t\t\t\t\t\t\t\t<input type=\"hidden\" name=\"sessionId\" value={session.id} />\n\t\t\t\t\t\t\t\t\t\t<button\n\t\t\t\t\t\t\t\t\t\t\tclass=\"rounded-lg border border-rose-900/70 bg-rose-950/30 px-4 py-2 font-medium text-rose-200\"\n\t\t\t\t\t\t\t\t\t\t\ttype=\"submit\"\n\t\t\t\t\t\t\t\t\t\t>\n\t\t\t\t\t\t\t\t\t\t\tCancel run\n\t\t\t\t\t\t\t\t\t\t</button>\n\t\t\t\t\t\t\t\t\t</form>\n\t\t\t\t\t\t\t\t{/if}\n\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t</article>\n\t\t\t\t\t{/each}\n\t\t\t\t{/if}\n\t\t\t</div>\n\t\t</section>\n\t</div>\n</section>\n","exit_code":0,"status":"completed"}}
