ltaMs / 60000));\n   103\t\n   104\t\tif (deltaMinutes < 1) return 'just now';\n   105\t\tif (deltaMinutes < 60) return `${deltaMinutes}m ago`;\n   106\t\n   107\t\tconst deltaHours = Math.round(deltaMinutes / 60);\n   108\t\tif (deltaHours < 24) return `${deltaHours}h ago`;\n   109\t\n   110\t\tconst deltaDays = Math.round(deltaHours / 24);\n   111\t\treturn `${deltaDays}d ago`;\n   112\t}\n   113\t\n   114\texport function summarizeControlPlane(data: ControlPlaneData) {\n   115\t\tconst runningTasks = data.tasks.filter((task) => task.status === 'running');\n   116\t\tconst blockedTasks = data.tasks.filter((task) => task.status === 'blocked');\n   117\t\tconst readyTasks = data.tasks.filter((task) => task.status === 'ready');\n   118\t\tconst onlineWorkers = data.workers.filter((worker) => worker.status !== 'offline');\n   119\t\tconst busyWorkers = data.workers.filter((worker) => worker.status === 'busy');\n   120\t\n   121\t\treturn {\n   122\t\t\ttaskCount: data.tasks.length,\n   123\t\t\trunningTaskCount: runningTasks.length,\n   124\t\t\tblockedTaskCount: blockedTasks.length,\n   125\t\t\treadyTaskCount: readyTasks.length,\n   126\t\t\tgoalCount: data.goals.length,\n   127\t\t\tworkerCount: data.workers.length,\n   128\t\t\tonlineWorkerCount: onlineWorkers.length,\n   129\t\t\tbusyWorkerCount: busyWorkers.length\n   130\t\t};\n   131\t}\n   132\t\n   133\texport function createGoalId() {\n   134\t\treturn `goal_${randomUUID()}`;\n   135\t}\n   136\t\n   137\texport function createTaskId() {\n   138\t\treturn `task_${randomUUID()}`;\n   139\t}\n   140\t\n   141\texport function createWorkerId() {\n   142\t\treturn `worker_${randomUUID()}`;\n   143\t}\n   144\t\n   145\texport function parseLane(value: string, fallback: Lane): Lane {\n   146\t\treturn isLane(value) ? value : fallback;\n   147\t}\n   148\t\n   149\texport function parsePriority(value: string, fallback: Priority): Priority {\n   150\t\treturn isPriority(value) ? value : fallback;\n   151\t}\n   15