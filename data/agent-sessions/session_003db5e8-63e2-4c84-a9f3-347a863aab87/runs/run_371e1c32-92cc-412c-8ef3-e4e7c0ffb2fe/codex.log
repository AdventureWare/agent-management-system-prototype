lve(path, entry.name);\n    51\t\t\t\tawait visit(nextPath, depth + 1);\n    52\t\t\t}\n    53\t\t}\n    54\t\n    55\t\tawait visit(rootPath, 0);\n    56\t\n    57\t\treturn [...results].sort((left, right) => left.localeCompare(right));\n    58\t}\n    59\t\n    60\tasync function loadFolderPickerOptions(): Promise<FolderOption[]> {\n    61\t\tconst groups = await Promise.all(\n    62\t\t\tFOLDER_PICKER_ROOTS.map(async (root) => {\n    63\t\t\t\tconst paths = await listFolderOptions(root.path, root.depth);\n    64\t\t\t\treturn paths.map((path) => ({\n    65\t\t\t\t\tpath,\n    66\t\t\t\t\tlabel: `${root.labelPrefix} · ${path.replace(`${root.path}/`, '').replace(root.path, '.')}`\n    67\t\t\t\t}));\n    68\t\t\t})\n    69\t\t);\n    70\t\n    71\t\treturn groups.flat();\n    72\t}\n    73\t\n    74\texport const load: PageServerLoad = async () => {\n    75\t\tconst sessions = await listAgentSessions();\n    76\t\n    77\t\treturn {\n    78\t\t\tsessions,\n    79\t\t\tsummary: summarizeAgentSessions(sessions),\n    80\t\t\tsandboxOptions: AGENT_SANDBOX_OPTIONS,\n    81\t\t\tfolderOptions: await loadFolderPickerOptions()\n    82\t\t};\n    83\t};\n    84\t\n    85\texport const actions: Actions = {\n    86\t\tstartSession: async ({ request }) => {\n    87\t\t\tconst form = await request.formData();\n    88\t\t\tconst name = form.get('name')?.toString().trim() ?? '';\n    89\t\t\tconst cwd = form.get('cwd')?.toString().trim() ?? '';\n    90\t\t\tconst prompt = form.get('prompt')?.toString().trim() ?? '';\n    91\t\t\tconst modelInput = form.get('model')?.toString().trim() ?? '';\n    92\t\t\tconst sandbox = parseAgentSandbox(form.get('sandbox')?.toString(), 'workspace-write');\n    93\t\n    94\t\t\tif (!name || !cwd || !prompt) {\n    95\t\t\t\treturn fail(400, { message: 'Name, cwd, and prompt are required.' });\n    96\t\t\t}\n    97\t\n    98\t\t\tawait startAgentSession({\n    99\t\t\t\tname,\n   100\t\t\t\tcwd,\n   101\t\t\t\tprompt,\n   102\t\t\t\tsandbox,\n   103\t\t\t\tmodel: modelInput || null\n   104\t\t\t});\n   105\t\n   106\t\t\treturn { ok: true };\n   107\t\t},\n   108\t\n   109\t\tsendMessage: async ({ request }) => {\n   110\t\t\tconst form = await request.formData();\n   111\t\t\tconst sessionId = form.get('sessionId')?.toString().trim() ?? '';\n   112\t\t\tconst prompt = form.get('prompt')?.toString().trim() ?? '';\n   113\t\n   114\t\t\tif (!sessionId || !prompt) {\n   115\t\t\t\treturn fail(400, { message: 'Session and prompt are required.' });\n   116\t\t\t}\n   117\t\n   118\t\t\ttry {\n   119\t\t\t\tawait sendAgentSessionMessage(sessionId, prompt);\n   120\t\t\t} catch (err) {\n   121\t\t\t\treturn fail(400, {\n   122\t\t\t\t\tmessage: err instanceof Error ? err.message : 'Could not queue session message.'\n   123\t\t\t\t});\n   124\t\t\t}\n   125\t\n   126\t\t\treturn { ok: true };\n   127\t\t},\n   128\t\n   129\t\tcancelRun: async ({ request }) => {\n   130\t\t\tconst form = await request.formData();\n   131\t\t\tconst sessionId = form.get('sessionId')?.toString().trim() ?? '';\n   132\t\n   133\t\t\tif (!sessionId) {\n   134\t\t\t\treturn fail(400, { message: 'Session is required.' });\n   135\t\t\t}\n   136\t\n   137\t\t\tconst canceled = await cancelAgentSession(sessionId);\n   138\t\n   139\t\t\tif (!canceled) {\n   140\t\t\t\treturn fail(400, { message: 'No active run was available to cancel.' });\n   141\t\t\t}\n   142\t\n   143\t\t\treturn { ok: true };\n   144\t\t}\n   145\t};\n","exit_code":0,"status":"completed"}}
