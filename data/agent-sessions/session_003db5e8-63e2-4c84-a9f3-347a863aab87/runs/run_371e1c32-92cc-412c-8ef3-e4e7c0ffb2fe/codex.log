{"type":"item.completed","item":{"id":"item_69","type":"command_execution","command":"/bin/zsh -lc \"nl -ba src/lib/server/worker-api.spec.ts | sed -n '1,260p'\"","aggregated_output":"     1\timport { describe, expect, it } from 'vitest';\n     2\timport {\n     3\t\tclaimTaskForWorker,\n     4\t\tgetWorkerTaskView,\n     5\t\thashWorkerToken,\n     6\t\tisWorkerEligibleForTask,\n     7\t\ttoPublicWorker,\n     8\t\tupdateTaskFromWorker,\n     9\t\tupdateWorkerHeartbeat\n    10\t} from './worker-api';\n    11\timport type { ControlPlaneData, Worker } from '$lib/types/control-plane';\n    12\t\n    13\tfunction buildFixture(): { data: ControlPlaneData; worker: Worker } {\n    14\t\tconst workerTokenHash = hashWorkerToken('secret-token');\n    15\t\tconst worker: Worker = {\n    16\t\t\tid: 'worker_one',\n    17\t\t\tname: 'Worker One',\n    18\t\t\tproviderId: 'provider_cloud_codex',\n    19\t\t\troleId: 'role_researcher',\n    20\t\t\tlocation: 'cloud',\n    21\t\t\tstatus: 'idle',\n    22\t\t\tcapacity: 2,\n    23\t\t\tregisteredAt: '2026-03-26T00:00:00.000Z',\n    24\t\t\tlastSeenAt: '2026-03-26T00:00:00.000Z',\n    25\t\t\tnote: 'fixture worker',\n    26\t\t\ttags: ['research'],\n    27\t\t\tauthTokenHash: workerTokenHash\n    28\t\t};\n    29\t\n    30\t\treturn {\n    31\t\t\tworker,\n    32\t\t\tdata: {\n    33\t\t\t\tproviders: [],\n    34\t\t\t\troles: [],\n    35\t\t\t\tgoals: [],\n    36\t\t\t\tworkers: [worker],\n    37\t\t\t\ttasks: [\n    38\t\t\t\t\t{\n    39\t\t\t\t\t\tid: 'task_ready_match',\n    40\t\t\t\t\t\ttitle: 'Ready match',\n    41\t\t\t\t\t\tsummary: 'ready task',\n    42\t\t\t\t\t\tlane: 'growth',\n    43\t\t\t\t\t\tgoalId: 'goal_1',\n    44\t\t\t\t\t\tpriority: 'high',\n    45\t\t\t\t\t\tstatus: 'ready',\n    46\t\t\t\t\t\tdesiredRoleId: 'role_researcher',\n    47\t\t\t\t\t\tassigneeWorkerId: null,\n    48\t\t\t\t\t\tartifactPath: '/tmp/one',\n    49\t\t\t\t\t\tcreatedAt: '2026-03-26T00:00:00.000Z',\n    50\t\t\t\t\t\tupdatedAt: '2026-03-26T00:00:00.000Z'\n    51\t\t\t\t\t},\n    52\t\t\t\t\t{\n    53\t\t\t\t\t\tid: 'task_running_assigned',\n    54\t\t\t\t\t\ttitle: 'Assigned',\n    55\t\t\t\t\t\tsummary: 'assigned task',\n    56\t\t\t\t\t\tlane: 'growth',\n    57\t\t\t\t\t\tgoalId: 'goal_1',\n    58\t\t\t\t\t\tpriority: 'high',\n    59\t\t\t\t\t\tstatus: 'running',\n    60\t\t\t\t\t\tdesiredRoleId: 'role_researcher',\n    61\t\t\t\t\t\tassigneeWorkerId: 'worker_one',\n    62\t\t\t\t\t\tartifactPath: '/tmp/two',\n    63\t\t\t\t\t\tcreatedAt: '2026-03-26T00:00:00.000Z',\n    64\t\t\t\t\t\tupdatedAt: '2026-03-26T00:00:00.000Z'\n    65\t\t\t\t\t},\n    66\t\t\t\t\t{\n    67\t\t\t\t\t\tid: 'task_ready_other_role',\n    68\t\t\t\t\t\ttitle: 'Other role',\n    69\t\t\t\t\t\tsummary: 'different role',\n    70\t\t\t\t\t\tlane: 'product',\n    71\t\t\t\t\t\tgoalId: 'goal_2',\n    72\t\t\t\t\t\tpriority: 'medium',\n    73\t\t\t\t\t\tstatus: 'ready',\n    74\t\t\t\t\t\tdesiredRoleId: 'role_app_worker',\n    75\t\t\t\t\t\tassigneeWorkerId: null,\n    76\t\t\t\t\t\tartifactPath: '/tmp/three',\n    77\t\t\t\t\t\tcreatedAt: '2026-03-26T00:00:00.000Z',\n    78\t\t\t\t\t\tupdatedAt: '2026-03-26T00:00:00.000Z'\n    79\t\t\t\t\t}\n    80\t\t\t\t]\n    81\t\t\t}\n    82\t\t};\n    83\t}\n    84\t\n    85\tdescribe('worker-api helpers', () => {\n    86\t\tit('omits authTokenHash from public worker output', () => {\n    87\t\t\tconst { worker } = buildFixture();\n    88\t\t\tconst publicWorker = toPublicWorker(worker);\n    89\t\n    90\t\t\texpect('authTokenHash' in publicWorker).toBe(false);\n    91\t\t\texpect(publicWorker.id).toBe(worker.id);\n    92\t\t});\n    93\t\n    94\t\tit('selects assigned and available tasks for a worker', () => {\n    95\t\t\tconst { data, worker } = buildFixture();\n    96\t\t\tconst view = getWorkerTaskView(data, worker);\n    97\t\n    98\t\t\texpect(view.assigned).toHaveLength(1);\n    99\t\t\texpect(view.available).toHaveLength(1);\n   100\t\t\texpect(view.available[0]?.id).toBe('task_ready_match');\n   101\t\t});\n   102\t\n   103\t\tit('claims a ready task for an eligible worker', () => {\n   104\t\t\tconst { data, worker } = buildFixture();\n   105\t\t\tconst next = claimTaskForWorker(data, worker, 'task_ready_match');\n   106\t\t\tconst claimed = next.tasks.find((task) => task.id === 'task_ready_match');\n   107\t\n   108\t\t\texpect(claimed?.assigneeWorkerId).toBe(worker.id);\n   109\t\t\texpect(claimed?.status).toBe('running');\n   110\t\t});\n   111\t\n   112\t\tit('updates worker heartbeat fields', () => {\n   113\t\t\tconst { data, worker } = buildFixture();\n   114\t\t\tconst next = updateWorkerHeartbeat(data, worker.id, {\n   115\t\t\t\tstatus: 'busy',\n   116\t\t\t\tcapacity: 4,\n   117\t\t\t\tnote: 'updated',\n   118\t\t\t\ttags: ['growth', 'citations']\n   119\t\t\t});\n   120\t\t\tconst updatedWorker = next.workers[0];\n   121\t\n   122\t\t\texpect(updatedWorker?.status).toBe('busy');\n   123\t\t\texpect(updatedWorker?.capacity).toBe(4);\n   124\t\t\texpect(updatedWorker?.note).toBe('updated');\n   125\t\t\texpect(updatedWorker?.tags).toEqual(['growth', 'citations']);\n   126\t\t});\n   127\t\n   128\t\tit('updates an assigned task status from the worker', () => {\n   129\t\t\tconst { data, worker } = buildFixture();\n   130\t\t\tconst next = updateTaskFromWorker(data, worker, {\n   131\t\t\t\ttaskId: 'task_running_assigned',\n   132\t\t\t\tstatus: 'review'\n   133\t\t\t});\n   134\t\t\tconst updatedTask = next.tasks.find((task) => task.id === 'task_running_assigned');\n   135\t\n   136\t\t\texpect(updatedTask?.status).toBe('review');\n   137\t\t});\n   138\t\n   139\t\tit('checks worker role eligibility correctly', () => {\n   140\t\t\tconst { data, worker } = buildFixture();\n   141\t\n   142\t\t\texpect(isWorkerEligibleForTask(worker, data.tasks[0]!)).toBe(true);\n   143\t\t\texpect(isWorkerEligibleForTask(worker, data.tasks[2]!)).toBe(false);\n   144\t\t});\n   145\t});\n","exit_code":0,"status":"completed"}}
