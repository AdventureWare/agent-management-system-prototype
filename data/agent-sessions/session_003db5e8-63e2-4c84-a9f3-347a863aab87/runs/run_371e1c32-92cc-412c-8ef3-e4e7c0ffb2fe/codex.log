e(raw) as Partial<AgentSessionsDb>;\n    47\t\n    48\t\t\treturn {\n    49\t\t\t\tsessions: Array.isArray(parsed.sessions) ? parsed.sessions : [],\n    50\t\t\t\truns: Array.isArray(parsed.runs) ? parsed.runs : []\n    51\t\t\t};\n    52\t\t} catch {\n    53\t\t\treturn defaultDb();\n    54\t\t}\n    55\t}\n    56\t\n    57\tasync function saveAgentSessionsDb(data: AgentSessionsDb) {\n    58\t\tawait mkdir(resolve(process.cwd(), 'data'), { recursive: true });\n    59\t\tawait writeFile(AGENT_SESSIONS_DB_FILE, JSON.stringify(data, null, 2));\n    60\t}\n    61\t\n    62\tasync function updateAgentSessionsDb(\n    63\t\tupdater: (data: AgentSessionsDb) => AgentSessionsDb | Promise<AgentSessionsDb>\n    64\t) {\n    65\t\tconst current = await loadAgentSessionsDb();\n    66\t\tconst next = await updater(current);\n    67\t\tawait saveAgentSessionsDb(next);\n    68\t\treturn next;\n    69\t}\n    70\t\n    71\tfunction createSessionId() {\n    72\t\treturn `session_${randomUUID()}`;\n    73\t}\n    74\t\n    75\tfunction createRunId() {\n    76\t\treturn `run_${randomUUID()}`;\n    77\t}\n    78\t\n    79\tfunction getRunPaths(sessionId: string, runId: string) {\n    80\t\tconst runDir = resolve(AGENT_SESSIONS_ROOT, sessionId, 'runs', runId);\n    81\t\n    82\t\treturn {\n    83\t\t\trunDir,\n    84\t\t\tlogPath: resolve(runDir, 'codex.log'),\n    85\t\t\tstatePath: resolve(runDir, 'state.json'),\n    86\t\t\tmessagePath: resolve(runDir, 'last-message.txt'),\n    87\t\t\tconfigPath: resolve(runDir, 'config.json')\n    88\t\t};\n    89\t}\n    90\t\n    91\tfunction getConfiguredCodexBin() {\n    92\t\treturn process.env.CODEX_BIN?.trim() || 'codex';\n    93\t}\n    94\t\n    95\texport function parseAgentSandbox(value: string | null | undefined, fallback: AgentSandbox) {\n    96\t\treturn value && isAgentSandbox(value) ? value : fallback;\n    97\t}\n    98\t\n    99\tasync function writeRunnerConfig(input: {\n   100\t\tsession: AgentSession;\n   101\t\trun: AgentRun;