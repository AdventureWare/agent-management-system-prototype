workerToken: string) {\n    53\t\tconst worker = data.workers.find((candidate) => candidate.id === workerId);\n    54\t\n    55\t\tif (!worker) {\n    56\t\t\tthrow error(404, 'Worker not found.');\n    57\t\t}\n    58\t\n    59\t\tif (!workerToken || worker.authTokenHash !== hashWorkerToken(workerToken)) {\n    60\t\t\tthrow error(401, 'Invalid worker token.');\n    61\t\t}\n    62\t\n    63\t\treturn worker;\n    64\t}\n    65\t\n    66\texport function isWorkerEligibleForTask(worker: Worker, task: Task) {\n    67\t\treturn worker.roleId === 'role_coordinator' || worker.roleId === task.desiredRoleId;\n    68\t}\n    69\t\n    70\texport function getWorkerTaskView(data: ControlPlaneData, worker: Worker) {\n    71\t\tconst assigned = data.tasks.filter(\n    72\t\t\t(task) => task.assigneeWorkerId === worker.id && task.status !== 'done'\n    73\t\t);\n    74\t\n    75\t\tconst available = data.tasks.filter(\n    76\t\t\t(task) =>\n    77\t\t\t\ttask.assigneeWorkerId === null &&\n    78\t\t\t\ttask.status === 'ready' &&\n    79\t\t\t\tisWorkerEligibleForTask(worker, task)\n    80\t\t);\n    81\t\n    82\t\treturn {\n    83\t\t\tassigned,\n    84\t\t\tavailable\n    85\t\t};\n    86\t}\n    87\t\n    88\texport function getWorkerQueueSummary(data: ControlPlaneData, worker: Worker) {\n    89\t\tconst tasks = getWorkerTaskView(data, worker);\n    90\t\n    91\t\treturn {\n    92\t\t\tassignedCount: tasks.assigned.length,\n    93\t\t\tavailableCount: tasks.available.length,\n    94\t\t\trunningAssignedCount: tasks.assigned.filter((task) => task.status === 'running').length\n    95\t\t};\n    96\t}\n    97\t\n    98\texport function updateWorkerHeartbeat(\n    99\t\tdata: ControlPlaneData,\n   100\t\tworkerId: string,\n   101\t\tinput: {\n   102\t\t\tstatus?: WorkerStatus;\n   103\t\t\tcapacity?: number;\n   104\t\t\tnote?: string;\n   105\t\t\ttags?: string[];\n   106\t\t}\n   107\t) {\n   108\t\treturn {\n   109\t\t\t...data,\n   110\t\t\tworkers: data.workers.map((worke